node_modules
dist
.DS_Store
.env
.env.*
!.env.example

# Input assets folder (資料夾結構追蹤、檔案內容不上傳)
input/**/*
!input/
!input/images/
!input/videos/
!input/audio/
!input/**/.gitkeep
!input/README.md
!input/USAGE.md

# Output assets folder (資料夾結構追蹤、渲染檔不上傳)
output/*
!output/.gitkeep

# Your private content (created from src/content.example.ts on install)
src/content.ts

# Archived video contents (private backups — run `npm run archive` 前的舊版)
src/videos-archive/

# Generated voiceover files & durations (regenerated by `npm run voiceover`)
public/voiceover/*.wav
public/voiceover/durations.json
!public/voiceover/.gitkeep

# Archived voiceover WAVs (private backups before regenerating)
public/voiceover-archive/

# Third-party background music (CC BY etc., download yourself)
public/music/*.mp3
!public/music/.gitkeep
