# ===== TTS provider 切換 =====
# 預設 elevenlabs;沒有 ElevenLabs 訂閱可改 gemini(免費 quota 即可)。
# TTS_PROVIDER=elevenlabs

# ===== ElevenLabs (預設 provider) =====
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# 在 ElevenLabs Voice Library,點 clone 完的 voice → 複製 Voice ID。
ELEVENLABS_VOICE_ID=your_voice_id_here

# (選填) Model 與取樣率
# 中文教學旁白建議 eleven_multilingual_v2(穩),想要表情多可換 eleven_v3。
# Sample rate 預設 24000(Starter / Creator 上限);Pro 才解鎖 44100。
# ELEVENLABS_MODEL=eleven_multilingual_v2
# ELEVENLABS_SAMPLE_RATE=24000

# ===== Gemini (備用 provider,免費 quota 充足) =====
# https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=your_gemini_key_here
# GEMINI_MODEL=gemini-2.5-flash-preview-tts
# GEMINI_VOICE=Aoede

# Meta Graph API tokens (Threads / Instagram)
# refresh API 需要 ACCESS_TOKEN + APP_SECRET 雙變數,APP_SECRET 在 Meta App Dashboard → 設定 → 基本資料
THREADS_ACCESS_TOKEN=
THREADS_APP_SECRET=
IG_ACCESS_TOKEN=
IG_APP_SECRET=